PORT=5000
NODE_ENV=development

# Supabase PostgreSQL
# Alternativ: komplette Connection String verwenden
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_key_change_this_in_production

# football-data.org API
FOOTBALL_DATA_API_KEY=your_football_data_api_key
FOOTBALL_DATA_COMPETITION_CODE=WC
# FOOTBALL_DATA_SEASON=2026

# Optional: RapidAPI (z.B. fuer Odds/Predictions)
# RAPIDAPI_PROVIDER=rapidapi
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOST=api-football-v1.p.rapidapi.com
# RAPIDAPI_TEST_PATH=/v3/timezone
# RAPIDAPI_ODDS_PATH=/v3/predictions
# RAPIDAPI_CACHE_TTL_MS=120000
# APIFOOTBALL_ENFORCE_DAILY_LIMIT=true
# APIFOOTBALL_DAILY_MAX_REQUESTS=80
# APIFOOTBALL_WARMUP_ENABLED=false
# APIFOOTBALL_WARMUP_INTERVAL_MINUTES=120
# APIFOOTBALL_WARMUP_MATCH_LIMIT=4
# APIFOOTBALL_WARMUP_HORIZON_DAYS=14
# APIFOOTBALL_INSIGHTS_CACHE_TTL_HOURS=24

# Alternative: Odds API direkt
# RAPIDAPI_PROVIDER=odds-api
# ODDS_API_KEY=your_odds_api_key
# ODDS_API_BASE_URL=https://api.odds-api.io/v3
# ODDS_API_EVENTS_PATH=/events
# ODDS_API_ODDS_PATH=/odds
# ODDS_API_SPORT=football
# ODDS_API_BOOKMAKERS=Bet365

# Alternative ohne RapidAPI: direkter API-SPORTS Key
# RAPIDAPI_PROVIDER=api-football-direct
# APIFOOTBALL_KEY=your_api_football_key_from_dashboard
# APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io

# CORS
FRONTEND_URL=http://localhost:5173
